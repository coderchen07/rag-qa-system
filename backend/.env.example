# ========== DeepSeek 配置（大模型）==========
# 获取方式：登录 DeepSeek 开放平台，在 API Key 管理页面创建
# 注意：不要填写真实密钥到代码仓库，运行时由 process.env 注入
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# DeepSeek 官方 API 地址（如网络需要可改为可用代理地址）
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# HuggingFace 模型下载镜像（用于本地 embedding 模型文件下载）
HF_ENDPOINT=https://hf-mirror.com

# ========== 服务配置 ==========
# PORT：NestJS 服务端口
# FRONTEND_ORIGIN：前端地址（用于后端跨域白名单）
PORT=3010
FRONTEND_ORIGIN=http://localhost:5173
