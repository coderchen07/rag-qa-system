# ========== DeepSeek 配置（大模型）==========
# 获取方式：登录 DeepSeek 开放平台，在 API Key 管理页面创建
# 注意：不要填写真实密钥到代码仓库，运行时由 process.env 注入
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# DeepSeek 官方 API 地址（如网络需要可改为可用代理地址）
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# HuggingFace 模型下载镜像（用于本地 embedding 模型文件下载）
HF_ENDPOINT=https://hf-mirror.com

# ========== 服务配置 ==========
# PORT：NestJS 服务端口
# FRONTEND_ORIGIN：前端地址（用于后端跨域白名单）
PORT=3010
FRONTEND_ORIGIN=http://localhost:5173

# ========== 群聊通知 Webhook（工具 create_ticket / send_notification）==========
# 用于将 AI 生成的通知发送到团队群聊机器人（当前默认使用飞书 interactive 卡片）。
# 未配置 Webhook 时，工具会返回友好提示："Webhook 未配置，请联系管理员"。
NOTIFICATION_WEBHOOK_URL=

# 飞书机器人「签名校验」密钥（与 tools.service.ts 中 create_ticket/send_notification 实现一致）。
# 未配置时，工具会返回："Webhook 或飞书签名密钥未配置，请联系管理员"。
FEISHU_SIGN_KEY=
